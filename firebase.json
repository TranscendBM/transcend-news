{
  "hosting": [
    {
      "target": "main",
      "public": "public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ]
    },
    {
      "target": "old",
      "public": "redirect",
      "redirects": [
        {
          "source": "**",
          "destination": "https://transcend-news.web.app",
          "type": 301
        }
      ]
    }
  ]
}
