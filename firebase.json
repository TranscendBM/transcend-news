{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "python311",
      "ignore": ["venv", "__pycache__", ".git", "*.local"]
    }
  ],
  "hosting": [
    {
      "target": "main",
      "public": "public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ]
    },
    {
      "target": "old",
      "public": "redirect",
      "redirects": [
        {
          "source": "**",
          "destination": "https://transcend-news.web.app",
          "type": 301
        }
      ]
    }
  ]
}
