rules_version = '2';

// ─────────────────────────────────────────────────────────────
// 創見新聞監控 — Firestore 安全規則
// 原則：前端實際讀取的集合開放「公開唯讀」；所有客戶端一律禁止寫入。
// 寫入僅由 Admin SDK 執行——正式排程為 Cloud Functions（transcend-news-tbm
// 專案的 functions/main.py），GitHub Actions 僅保留手動備援觸發。
// Admin SDK 繞過規則，因此 write: false 只擋客戶端，不影響排程。
//
// 內部集合 meta/*（排程鎖 lock_*、去重索引分片 newsIndex_0..f）
// 由檔末的預設拒絕涵蓋：客戶端不可讀寫，僅 Admin SDK 存取。
//
// 部署位置：這份規則屬於「資料庫專案 transcend-news-monitor」（舊 Google 帳號），
// 不是 Hosting 專案 transcend-news-tbm。部署方式見 README「Firestore Rules 部署」。
// ─────────────────────────────────────────────────────────────
service cloud.firestore {
  match /databases/{database}/documents {

    // 新聞（前端以 collection query 讀取）
    match /news/{articleId} {
      allow read: if true;
      allow write: if false;
    }

    // 即時股價（前端讀 stocks/latest 單一文件，並以 onSnapshot 監聽）
    match /stocks/latest {
      allow read: if true;
      allow write: if false;
    }

    // 月營收（前端讀 revenue/2451 與競品 3260/8271/4967/5289/4973）
    match /revenue/{stockCode} {
      allow read: if true;
      allow write: if false;
    }

    // 季度損益（前端讀 financials/2451）
    match /financials/{stockCode} {
      allow read: if true;
      allow write: if false;
    }

    // 股利（前端讀 dividends/2451）
    match /dividends/{stockCode} {
      allow read: if true;
      allow write: if false;
    }

    // 競品重大訊息（前端讀 material/competitors 單一文件）
    match /material/competitors {
      allow read: if true;
      allow write: if false;
    }

    // 每日交易資料（前端讀 daily/2451）
    match /daily/{stockCode} {
      allow read: if true;
      allow write: if false;
    }

    // 其他未列出的集合一律拒絕（讀＋寫）
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
